  "source": "\n\ncontract EtherGame \n{\n    uint[] a;\n    function Test1() public returns(address)\n    {\n        return msg.sender;\n    }\n    function Test2() returns(address)\n    {\n        return msg.sender;\n    }\n    function Test3() public returns(uint)\n    {\n        return a.length;\n    }\n    function Test4() returns(uint)\n    {\n        return a.length;\n    }\n    function Kill()\n    {\n        selfdestruct(msg.sender);\n    }\n}",
